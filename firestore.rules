rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Shared family data: any signed-in user can read and write.
    // There's a single shared family account, so no per-user ownership checks.
    match /entries/{entryId} {
      allow read, write: if request.auth != null;
    }

    match /shopping/{itemId} {
      allow read, write: if request.auth != null;
    }

    // User profile docs (created on registration in AuthView.tsx):
    // anyone signed in can read them, but you can only write your own.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
